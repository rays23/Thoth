# YouTube Data API v3
YOUTUBE_API_KEY=your-api-key-here

# Whisper settings
WHISPER_BACKEND=mlx
# Options: mlx (Apple Silicon, recommended on Mac), openai (CPU/CUDA)
WHISPER_MODEL=mlx-community/whisper-large-v3-mlx
# MLX models: mlx-community/whisper-large-v3-mlx, mlx-community/whisper-small-mlx
# OpenAI models: tiny, base, small, medium, large-v3
WHISPER_LANGUAGE=
# Leave empty for auto-detect, or set e.g. "en", "de"

# Output
OUTPUT_DIR=output
KEEP_AUDIO=false

# Processing
YOUTUBE_BATCH_SIZE=50
RATE_LIMIT_DELAY=0.5
